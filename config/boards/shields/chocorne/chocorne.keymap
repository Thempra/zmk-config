 * SPDX-License-Identifier: MIT
 *
 * Chocorne keymap — Dev Edition (Python · Go · TypeScript)
 * SO: Español (ES) | Editor: VS Code | Terminal: uso intensivo
 *
 * Filosofía de diseño:
 *  · Brackets/parens siempre como macros de par (abre+cierra, cursor en medio)
 *  · Backtick, comillas simples y dobles en posiciones de 1 tecla
 *  · Pipe, slash y operadores de terminal cómodos en LOWER
 *  · Atajos VS Code frecuentes en RAISE (sin mover manos del homerow)
 *  · Español completo: Ñ por combo, acentos y ¿¡ en SYM
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>

// ─── Capas ────────────────────────────────────────────────────────────────────
#define DEF_L 0   // Default QWERTY
#define LOW_L 1   // Lower   — símbolos programación
#define RAI_L 2   // Raise   — números + F-keys + VS Code shortcuts
#define NAV_L 3   // Nav     — navegación + terminal
#define NUM_L 4   // Numpad  — calculadora
#define BLE_L 5   // BLE     — Bluetooth / sistema
#define SYM_L 6   // Sym     — símbolos ES escritura

// ─── Keycodes ES (teclado físico Español) ─────────────────────────────────────
// Brackets y agrupadores
#define ES_LBRC   RA(GRAVE)      // {
#define ES_RBRC   RA(PLUS)       // }
#define ES_LBKT   RA(LBKT)       // [
#define ES_RBKT   RA(RBKT)       // ]
#define ES_LPAR   LS(N8)         // (
#define ES_RPAR   LS(N9)         // )
#define ES_LT     NUBS           // <
#define ES_GT     LS(NUBS)       // >
// Comillas y literales
#define ES_APOS   NUHS           // '  (tecla # física en ES)
#define ES_DQUOT  LS(N2)         // "
#define ES_BKTK   RA(BSLH)       // `  (AltGr + \)
// Operadores
#define ES_PIPE   RA(N1)         // |
#define ES_BSLH   RA(MINUS)      // Backslash
#define ES_AT     RA(N2)         // @
#define ES_HASH   RA(N3)         // #
#define ES_TILDE  RA(N4)         // ~
#define ES_EURO   RA(N5)         // €
#define ES_CARET  LS(LBKT)       // ^
#define ES_PLUS   RBKT            // +
#define ES_MINUS  FSLH            // -
#define ES_UNDER  LS(FSLH)       // _
#define ES_EQUAL  LS(N0)         // =
#define ES_FSLH   LS(N7)         // /
#define ES_STAR   LS(RBKT)       // *
#define ES_AMPR   LS(N6)         // &
#define ES_DLLR   LS(N4)         // $
#define ES_PRCNT  LS(N5)         // %
#define ES_EXCL   LS(N1)         // !
#define ES_SCLN   LS(COMMA)      // ;
#define ES_COLN   LS(DOT)        // :
#define ES_IQUES  LS(MINUS)      // ?
#define ES_IEXCL  RA(N1)         // ¡
#define ES_MIDDOT LS(N3)         // ·
// Español
#define ES_NTIL   SEMI           // Ñ  (tecla ; en ES)
#define ES_ACUT   LBKT           // ´  dead acute → á é í ó ú

// VS Code atajos (Windows)
#define VS_FMT    LC(LS(I))      // Format document
#define VS_TERM   LC(GRAVE)      // Toggle terminal integrado
#define VS_SB     LC(B)          // Toggle sidebar
#define VS_QFX    LC(DOT)        // Quick fix / code action
#define VS_REN    LC(F2)         // Rename symbol
#define VS_DEF    LC(F12)        // Go to definition
#define VS_PAL    LC(LS(P))      // Command palette
#define VS_SRCH   LC(LS(F))      // Search en proyecto
#define WIN_SNIP  LG(LS(S))      // Recorte de pantalla


/ {
    // =========================================================================
    // BEHAVIORS
    // =========================================================================
    behaviors {

        // Homerow estándar — dedos medios (S D / K L)
        ht: hold_tap {
            compatible = "zmk,behavior-hold-tap";
            label = "HT";
            #binding-cells = <2>;
            tapping-term-ms = <220>;
            quick-tap-ms = <175>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };

        // Homerow rápido — índices (F / J)
        htf: hold_tap_fast {
            compatible = "zmk,behavior-hold-tap";
            label = "HTF";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };

        // Homerow lento — meñiques (A / Ñ)
        // tap-preferred: evita falsos positivos en posiciones de esquina
        hts: hold_tap_slow {
            compatible = "zmk,behavior-hold-tap";
            label = "HTS";
            #binding-cells = <2>;
            tapping-term-ms = <260>;
            quick-tap-ms = <175>;
            flavor = "tap-preferred";
            bindings = <&kp>, <&kp>;
        };
    };

    // =========================================================================
    // MACROS — pares de símbolos (abre + cierra, cursor entre ellos)
    // =========================================================================
    macros {

        // ()
        m_parens: macro_parens {
            compatible = "zmk,behavior-macro";
            label = "M_PARENS";
            #binding-cells = <0>;
            bindings = <&kp ES_LPAR &kp ES_RPAR &kp LEFT>;
        };

        // []
        m_bkts: macro_brackets {
            compatible = "zmk,behavior-macro";
            label = "M_BKTS";
            #binding-cells = <0>;
            bindings = <&kp ES_LBKT &kp ES_RBKT &kp LEFT>;
        };

        // {}
        m_brcs: macro_braces {
            compatible = "zmk,behavior-macro";
            label = "M_BRCS";
            #binding-cells = <0>;
            bindings = <&kp ES_LBRC &kp ES_RBRC &kp LEFT>;
        };

        // ""
        m_dquot: macro_dquot {
            compatible = "zmk,behavior-macro";
            label = "M_DQUOT";
            #binding-cells = <0>;
            bindings = <&kp ES_DQUOT &kp ES_DQUOT &kp LEFT>;
        };

        // ''
        m_squot: macro_squot {
            compatible = "zmk,behavior-macro";
            label = "M_SQUOT";
            #binding-cells = <0>;
            bindings = <&kp ES_APOS &kp ES_APOS &kp LEFT>;
        };

        // ``
        m_bktk: macro_backtick {
            compatible = "zmk,behavior-macro";
            label = "M_BKTK";
            #binding-cells = <0>;
            bindings = <&kp ES_BKTK &kp ES_BKTK &kp LEFT>;
        };

        // ``` — triple backtick (Python docstrings / Markdown)
        m_trbk: macro_triple_backtick {
            compatible = "zmk,behavior-macro";
            label = "M_TRBK";
            #binding-cells = <0>;
            bindings = <&kp ES_BKTK &kp ES_BKTK &kp ES_BKTK>;
        };

        // -> — arrow operator (Go, C, Python type hints)
        m_arrow: macro_arrow {
            compatible = "zmk,behavior-macro";
            label = "M_ARROW";
            #binding-cells = <0>;
            bindings = <&kp ES_MINUS &kp ES_GT>;
        };

        // => — fat arrow (TypeScript, JS)
        m_farrow: macro_fat_arrow {
            compatible = "zmk,behavior-macro";
            label = "M_FARROW";
            #binding-cells = <0>;
            bindings = <&kp ES_EQUAL &kp ES_GT>;
        };

        // := — walrus (Python 3.8+) / declaración corta Go
        m_walrus: macro_walrus {
            compatible = "zmk,behavior-macro";
            label = "M_WALRUS";
            #binding-cells = <0>;
            bindings = <&kp ES_COLN &kp ES_EQUAL>;
        };

        // :: — scope / namespaces (TypeScript, Go)
        m_scope: macro_scope {
            compatible = "zmk,behavior-macro";
            label = "M_SCOPE";
            #binding-cells = <0>;
            bindings = <&kp ES_COLN &kp ES_COLN>;
        };

        // ... — spread / ellipsis (JS/TS, Python)
        m_dots: macro_ellipsis {
            compatible = "zmk,behavior-macro";
            label = "M_DOTS";
            #binding-cells = <0>;
            bindings = <&kp DOT &kp DOT &kp DOT>;
        };
    };

    // =========================================================================
    // COMBOS
    // =========================================================================
    combos {
        compatible = "zmk,combos";

        // ── Escritura general ─────────────────────────────────────────────────

        // ESC: Q + W
        combo_esc {
            timeout-ms = <35>;
            key-positions = <1 2>;
            bindings = <&kp ESC>;
            layers = <DEF_L>;
        };

        // Caps Word: F + J — mayúsculas temporales (útil para constantes: MY_CONST)
        combo_caps_word {
            timeout-ms = <40>;
            key-positions = <15 19>;
            bindings = <&caps_word>;
            layers = <DEF_L>;
        };

        // Ñ: N + M
        combo_enie {
            timeout-ms = <40>;
            key-positions = <25 26>;
            bindings = <&kp ES_NTIL>;
            layers = <DEF_L>;
        };

        // ¿: coma + punto
        combo_iques {
            timeout-ms = <40>;
            key-positions = <27 28>;
            bindings = <&kp ES_IQUES>;
            layers = <DEF_L>;
        };

        // DEL: O + P
        combo_del {
            timeout-ms = <35>;
            key-positions = <9 10>;
            bindings = <&kp DEL>;
            layers = <DEF_L>;
        };

        // BKSP extra: I + O
        combo_bksp {
            timeout-ms = <35>;
            key-positions = <8 9>;
            bindings = <&kp BSPC>;
            layers = <DEF_L>;
        };

        // ── Programación ─────────────────────────────────────────────────────

        // ->  H + J (homerow derecha, adyacentes)
        combo_arrow {
            timeout-ms = <40>;
            key-positions = <18 19>;
            bindings = <&m_arrow>;
            layers = <DEF_L LOW_L>;
        };

        // =>  J + K
        combo_fat_arrow {
            timeout-ms = <40>;
            key-positions = <19 20>;
            bindings = <&m_farrow>;
            layers = <DEF_L LOW_L>;
        };

        // :=  K + L
        combo_walrus {
            timeout-ms = <40>;
            key-positions = <20 21>;
            bindings = <&m_walrus>;
            layers = <DEF_L LOW_L>;
        };

        // ``` W + E (Python docstring / Markdown code block)
        combo_triple_bktk {
            timeout-ms = <40>;
            key-positions = <2 3>;
            bindings = <&m_trbk>;
            layers = <DEF_L>;
        };

        // ... R + T (spread/ellipsis)
        combo_ellipsis {
            timeout-ms = <40>;
            key-positions = <4 5>;
            bindings = <&m_dots>;
            layers = <DEF_L>;
        };

        // ── Sistema ───────────────────────────────────────────────────────────

        // BLE layer: pulgares interiores (ENTER + SPACE)
        combo_ble {
            timeout-ms = <50>;
            key-positions = <39 40>;
            bindings = <&mo BLE_L>;
            layers = <DEF_L LOW_L RAI_L>;
        };
    };

    // =========================================================================
    // KEYMAP
    // =========================================================================
    keymap {
        compatible = "zmk,keymap";

        studio_unlock: studio_unlock {
            compatible = "zmk,behavior-studio-unlock";
            #binding-cells = <0>;
        };

        // ─────────────────────────────────────────────────────────────────────
        // 0 · DEFAULT
        // ─────────────────────────────────────────────────────────────────────
        //
        // ┌───────┬───┬───┬───┬───┬───┐   ┌───┬───┬───┬───┬───┬───────┐
        // │  TAB  │ Q │ W │ E │ R │ T │   │ Y │ U │ I │ O │ P │ BKSP  │
        // ├───────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼───────┤
        // │ LSHFT │GUI│ALT│CTL│SHF│ G │   │ H │SHF│CTL│ALT│GUI│  '    │
        // │       │ A │ S │ D │ F │   │   │   │ J │ K │ L │ Ñ │       │
        // ├───────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼───────┤
        // │ LCTRL │ Z │ X │ C │ V │ B │   │ N │ M │ , │ . │ - │ ENTER │
        // └───────┴───┴───┴─┬─┴─┬─┴─┬┘   └┬──┴─┬─┴─┬─┴───┴───┴───────┘
        //                   │LOW│RAI│ENT   │SPC │NUM│NAV│
        //                   └───┴───┴───   └────┴───┴───┘
        //
        // Combos activos en DEFAULT:
        //   Q+W → ESC        F+J → CapsWord     N+M → Ñ
        //   ,+. → ¿          O+P → DEL           I+O → BKSP
        //   W+E → ```        R+T → ...
        //   H+J → ->         J+K → =>            K+L → :=
        //   ENT+SPC → BLE
        //
        default_layer {
            bindings = <
&kp TAB    &kp Q          &kp W        &kp E         &kp R          &kp T        &kp Y      &kp U          &kp I         &kp O        &kp P              &kp BSPC
&kp LSHFT  &hts LGUI A    &ht LALT S   &ht LCTRL D   &htf LSHFT F   &kp G        &kp H      &htf RSHFT J   &ht RCTRL K   &ht LALT L   &hts RGUI ES_NTIL  &kp ES_APOS
&kp LCTRL  &kp Z          &kp X        &kp C         &kp V          &kp B        &kp N      &kp M          &kp COMMA     &kp DOT      &kp ES_MINUS       &kp ENTER
                                        &mo LOW_L     &mo RAI_L      &kp ENTER    &kp SPACE  &mo NUM_L      &mo NAV_L
            >;
        };

        // ─────────────────────────────────────────────────────────────────────
        // 1 · LOWER — Símbolos de programación
        // ─────────────────────────────────────────────────────────────────────
        //
        // Izquierda: operadores sueltos (para escribir a mano cuando el combo
        //            no encaja, p.ej. dentro de expresiones complejas)
        // Derecha: pares auto-cerrados con cursor en medio
        //
        // ┌─────┬─────┬─────┬─────┬─────┬─────┐   ┌─────┬─────┬─────┬─────┬─────┬─────┐
        // │ ESC │  !  │  @  │  #  │  $  │  %  │   │  ^  │ ()⌶ │ []⌶ │ {}⌶ │ ``⌶ │ DEL │
        // ├─────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┼─────┤
        // │  ~  │  &  │  *  │  /  │  \  │  |  │   │  =  │  +  │  -  │  _  │  ;  │  :  │
        // ├─────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┼─────┤
        // │  <  │  >  │ ""⌶ │ ''⌶ │```  │SNIP │   │  ?  │  <  │  >  │  `  │     │     │
        // └─────┴─────┴─────┴──┬──┴──┬──┴──┬──┘   └──┬──┴──┬──┴──┬──┴─────┴─────┴─────┘
        //                      │▓▓▓▓▓│ GUI │SPC      │SPC │     │     │
        //                      └─────┴─────┴─────    └─────┴─────┴─────┘
        // ⌶ = macro par, cursor queda entre los dos caracteres
        // Combos ->  =>  := siguen activos en esta capa
        //
        lower_layer {
            bindings = <
&kp ESC      &kp ES_EXCL  &kp ES_AT    &kp ES_HASH   &kp ES_DLLR   &kp ES_PRCNT    &kp ES_CARET  &m_parens    &m_bkts      &m_brcs      &m_bktk      &kp DEL
&kp ES_TILDE &kp ES_AMPR  &kp ES_STAR  &kp ES_FSLH   &kp ES_BSLH   &kp ES_PIPE     &kp ES_EQUAL  &kp ES_PLUS  &kp ES_MINUS &kp ES_UNDER &kp ES_SCLN  &kp ES_COLN
&kp ES_LT    &kp ES_GT    &m_dquot     &m_squot      &m_trbk       &kp WIN_SNIP    &kp ES_IQUES  &kp ES_LT    &kp ES_GT    &kp ES_BKTK  &trans       &trans
                                        &trans        &kp LGUI      &kp SPACE       &kp SPACE     &trans       &trans
            >;
        };

        // ─────────────────────────────────────────────────────────────────────
        // 2 · RAISE — Números + F-keys + VS Code
        // ─────────────────────────────────────────────────────────────────────
        //
        // ┌──────┬───┬───┬───┬───┬─────┐   ┌─────┬─────┬─────┬─────┬─────┬─────────┐
        // │  `   │ 1 │ 2 │ 3 │ 4 │  5  │   │  6  │  7  │  8  │  9  │  0  │   DEL   │
        // ├──────┼───┼───┼───┼───┼─────┤   ├─────┼─────┼─────┼─────┼─────┼─────────┤
        // │  F1  │F2 │F3 │F4 │F5 │  F6 │   │  F7 │  F8 │  F9 │ F10 │ F11 │   F12   │
        // ├──────┼───┼───┼───┼───┼─────┤   ├─────┼─────┼─────┼─────┼─────┼─────────┤
        // │ CAPS │PAL│TRM│FMT│SRH│     │   │     │ QFX │ REN │ DEF │     │ CA(DEL) │
        // └──────┴───┴───┴─┬─┴─┬─┴─┬──┘   └──┬──┴──┬──┴──┬──┴─────┴─────┴─────────┘
        //                  │BLE│▓▓▓│SYM      │    │    │    │
        //                  └───┴───┴───      └────┴────┴────┘
        //
        // Fila 3 izq = VS Code workflow:
        //   PAL = Command Palette (Ctrl+Shift+P)
        //   TRM = Toggle Terminal  (Ctrl+`)
        //   FMT = Format Document  (Ctrl+Shift+I)
        //   SRH = Search en repo   (Ctrl+Shift+F)
        // Fila 3 der = refactoring:
        //   QFX = Quick Fix        (Ctrl+.)
        //   REN = Rename Symbol    (Ctrl+F2)
        //   DEF = Go to Definition (Ctrl+F12)
        //
        raise_layer {
            bindings = <
&kp GRAVE  &kp N1       &kp N2       &kp N3       &kp N4       &kp N5         &kp N6   &kp N7      &kp N8      &kp N9       &kp N0   &kp DEL
&kp F1     &kp F2       &kp F3       &kp F4       &kp F5       &kp F6         &kp F7   &kp F8      &kp F9      &kp F10      &kp F11  &kp F12
&kp CAPS   &kp VS_PAL   &kp VS_TERM  &kp VS_FMT   &kp VS_SRCH  &trans         &trans   &kp VS_QFX  &kp VS_REN  &kp VS_DEF   &trans   &kp LA(LC(DEL))
                                      &mo BLE_L    &trans       &mo SYM_L      &trans   &trans      &trans
            >;
        };

        // ─────────────────────────────────────────────────────────────────────
        // 3 · NAV — Navegación + Terminal + Edición
        // ─────────────────────────────────────────────────────────────────────
        //
        // ┌─────┬──────┬──────┬──────┬──────┬──────┐   ┌──────┬──────┬──────┬──────┬──────┬──────┐
        // │ TAB │      │      │      │      │      │   │      │ HOME │  ↑   │  END │ PGUP │ BKSP │
        // ├─────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
        // │ ESC │ GUI  │ ALT  │ CTRL │ SHFT │      │   │      │  ←   │  ↓   │  →   │ PGDN │      │
        // ├─────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
        // │     │ UNDO │ CUT  │ COPY │PASTE │      │   │      │ W←   │      │  W→  │      │      │
        // └─────┴──────┴──────┴──┬───┴──┬───┴──┬───┘   └──┬───┴──┬───┴──┬───┴──────┴──────┴──────┘
        //                        │      │      │          │      │      │▓▓▓│
        //                        └──────┴──────┴──────    └──────┴──────┴───┘
        //
        // Tip: mantén D (CTRL) + flecha = saltar palabra en terminal
        //      mantén F (SHFT) + flecha = seleccionar texto
        //      mantén D (CTRL) + W←/W→ = saltar palabra (Ctrl+Left/Right)
        //
        nav_layer {
            bindings = <
&kp TAB  &trans        &trans       &trans        &trans         &trans       &trans  &kp HOME      &kp UP    &kp END        &kp PG_UP  &kp BSPC
&kp ESC  &hts LGUI A   &ht LALT S   &ht LCTRL D   &htf LSHFT F   &trans       &trans  &kp LEFT      &kp DOWN  &kp RIGHT      &kp PG_DN  &trans
&trans   &kp LC(Z)     &kp LC(X)    &kp LC(C)     &kp LC(V)      &trans       &trans  &kp LC(LEFT)  &trans    &kp LC(RIGHT)  &trans     &trans
                                     &trans        &trans         &trans       &trans  &trans        &trans
            >;
        };

        // ─────────────────────────────────────────────────────────────────────
        // 4 · NUMPAD — Layout calculadora + F-keys
        // ─────────────────────────────────────────────────────────────────────
        //
        // ┌──────┬───┬───┬───┬──────┬──────┐   ┌──────┬────┬────┬────┬────┬──────┐
        // │   /  │ 7 │ 8 │ 9 │  *   │ BKSP │   │ BKSP │ F1 │ F2 │ F3 │ F4 │ BKSP │
        // ├──────┼───┼───┼───┼──────┼──────┤   ├──────┼────┼────┼────┼────┼──────┤
        // │   -  │ 4 │ 5 │ 6 │  +   │      │   │      │ F5 │ F6 │ F7 │ F8 │      │
        // ├──────┼───┼───┼───┼──────┼──────┤   ├──────┼────┼────┼────┼────┼──────┤
        // │   =  │ 1 │ 2 │ 3 │ ENTR │      │   │      │ F9 │F10 │F11 │F12 │ ENT  │
        // └──────┴───┴───┴─┬─┴──┬───┴─┬────┘   └──┬───┴─┬──┴─┬──┴────┴────┴──────┘
        //                  │ 0  │  ,  │  .        │     │▓▓▓│   │
        //                  └────┴─────┴───        └─────┴────┴───┘
        //
        num_layer {
            bindings = <
&kp ES_FSLH   &kp N7  &kp N8  &kp N9  &kp ES_STAR   &kp BSPC     &kp BSPC   &kp F1   &kp F2   &kp F3   &kp F4   &kp BSPC
&kp ES_MINUS  &kp N4  &kp N5  &kp N6  &kp ES_PLUS   &trans       &trans     &kp F5   &kp F6   &kp F7   &kp F8   &trans
&kp ES_EQUAL  &kp N1  &kp N2  &kp N3  &kp ENTER     &trans       &trans     &kp F9   &kp F10  &kp F11  &kp F12  &kp ENTER
                               &kp N0  &kp COMMA     &kp DOT      &kp SPACE  &trans   &trans
            >;
        };

        // ─────────────────────────────────────────────────────────────────────
        // 5 · BLE — Bluetooth / Sistema
        // ─────────────────────────────────────────────────────────────────────
        //
        // BT_SEL 0-4 : seleccionar perfil BT
        // OUT_TOG    : alternar BT ↔ USB
        // BT_CLR     : desemparejar perfil actual
        // sys_reset  : reset firmware
        // bootloader : modo DFU (flashear nuevo firmware)
        //
        ble_layer {
            bindings = <
&studio_unlock &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4    &out OUT_TOG  &trans      &trans       &trans       &trans  &trans
&trans       &trans        &trans        &trans        &trans        &trans          &sys_reset    &bt BT_CLR  &bt BT_PRV   &bt BT_NXT   &trans  &trans
&bootloader  &trans        &trans        &trans        &trans        &trans          &trans        &trans      &trans       &trans       &trans  &bootloader
                                        &trans        &trans        &trans          &trans        &trans      &trans
            >;
        };

        // ─────────────────────────────────────────────────────────────────────
        // 6 · SYM — Símbolos ES escritura (desde RAISE, pulgar der. centro)
        // ─────────────────────────────────────────────────────────────────────
        //
        // Para escritura en español sin salir del flujo:
        // vocales con acento, ¡ ¿ · € y símbolos de puntuación menos frecuentes
        //
        // ┌─────┬─────┬─────┬─────┬─────┬─────┐   ┌─────┬─────┬─────┬─────┬─────┬─────┐
        // │     │  ¡  │  ¿  │  ·  │  €  │     │   │     │  ú  │  í  │  ó  │  ü  │     │
        // ├─────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┼─────┤
        // │     │  á  │  é  │     │     │     │   │     │     │     │     │     │     │
        // ├─────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┼─────┤
        // │     │     │     │  ©  │  ®  │  ™  │   │     │     │     │     │     │     │
        // └─────┴─────┴─────┴──┬──┴──┬──┴──┬──┘   └──┬──┴──┬──┴──┬──┴─────┴─────┴─────┘
        //                      │     │     │▓▓▓      │     │     │   │
        //                      └─────┴─────┴─────    └─────┴─────┴───┘
        //
        // Nota: en teclado ES, RA(vocal) produce la vocal con acento
        //
        sym_layer {
            bindings = <
&trans  &kp ES_IEXCL   &kp ES_IQUES    &kp ES_MIDDOT  &kp ES_EURO  &trans      &trans  &kp RA(U)  &kp RA(I)  &kp RA(O)  &kp RA(Y)  &trans
&trans  &kp RA(A)      &kp RA(E)       &trans         &trans       &trans      &trans  &trans     &trans     &trans     &trans     &trans
&trans  &trans         &trans          &kp RA(C)      &kp RA(R)    &kp RA(T)   &trans  &trans     &trans     &trans     &trans     &trans
                                        &trans         &trans       &trans      &trans  &trans     &trans
            >;
        };
    };
};
